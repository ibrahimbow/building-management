CHAT_DB_PASSWORD=bm_password

AUTH_JWT_SECRET=myVeryLongSecureJwtSecretKeyForBuildingManagement2026AtLeast32Chars
AUTH_JWT_EXPIRATION_MINUTES=60

AUTH_SERVICE_URL=http://bm-auth-service:8081
BUILDING_SERVICE_URL=http://bm-building-service:8083
ANNOUNCEMENT_SERVICE_URL=http://bm-announcement-service:8084
