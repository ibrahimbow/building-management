AUTH_DB_URL=jdbc:postgresql://postgres:5432/auth_db
AUTH_DB_USERNAME=bm_user
AUTH_DB_PASSWORD=bm_password

BUILDING_DB_URL=jdbc:postgresql://postgres:5432/building_db
BUILDING_DB_USERNAME=bm_user
BUILDING_DB_PASSWORD=bm_password

ANNOUNCEMENT_DB_URL=jdbc:postgresql://postgres:5432/announcement_db
ANNOUNCEMENT_DB_USERNAME=bm_user
ANNOUNCEMENT_DB_PASSWORD=bm_password

SHARE_AND_HELP_DB_URL=jdbc:postgresql://postgres:5432/share_and_help_db
